# 이 파일을 .env로 복사한 뒤 값을 채우세요 (.env는 git에 올라가지 않음)

# DART OpenAPI 키 — https://opendart.fss.or.kr 에서 무료 발급
DART_API_KEY=

# Gemini API 키 — https://aistudio.google.com/apikey 에서 무료 발급
GEMINI_API_KEY=
# 무료 티어 모델. 정책 바뀌면 여기만 수정
GEMINI_MODEL=gemini-2.5-flash

# Gmail SMTP — 구글 계정 2단계 인증 켜고 "앱 비밀번호" 발급 (SETUP.md 참고)
SMTP_USER=your@gmail.com
SMTP_PASSWORD=
# 브리핑 받을 주소 (쉼표로 여러 명 가능)
MAIL_TO=your@gmail.com

# 선택 옵션
# SEND_EMAIL=false        # 웹 대시보드만 쓰고 메일은 끄기
# LOOKBACK_DAYS=1
# DOC_MAX_CHARS=8000
# SEND_EMPTY_BRIEFING=false
