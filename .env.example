# 이 파일을 .env로 복사한 뒤 값을 채우세요 (.env는 git에 올라가지 않음)

# DART OpenAPI 키 — https://opendart.fss.or.kr 에서 무료 발급
DART_API_KEY=

# Gemini API 키 — https://aistudio.google.com/apikey 에서 무료 발급
GEMINI_API_KEY=
# 무료 티어 모델. 정책 바뀌면 여기만 수정
GEMINI_MODEL=gemini-2.5-flash
# Phase 2-2 웹 답변 모델. 비워두면 GEMINI_MODEL을 사용
# GEMINI_ANSWER_MODEL=gemini-2.5-flash-lite
# EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_DIM=768

# Gmail SMTP — 구글 계정 2단계 인증 켜고 "앱 비밀번호" 발급 (SETUP.md 참고)
SMTP_USER=your@gmail.com
SMTP_PASSWORD=
# 브리핑 받을 주소 (쉼표로 여러 명 가능)
MAIL_TO=your@gmail.com

# Phase 2 (RAG) — Supabase 프로젝트 (비워두면 임베딩 저장 건너뜀)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SECRET_KEY=sb_secret_...
# RAG_MATCH_COUNT=8
# RAG_MIN_SIMILARITY=0.35

# Phase 2-2 공개 질문 API rate limit (서버 전용)
# UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
# RATE_LIMIT_IP_HASH_KEY=replace-with-a-long-random-secret
# 확정 실측 한도의 80%: 답변 8 RPM/16 RPD, 임베딩 80 RPM/800 RPD
# RATE_LIMIT_GLOBAL_RPM=8
# GEMINI_EMBEDDING_RPM_LIMIT=80
# GEMINI_EMBEDDING_DAILY_BUDGET=800
# GEMINI_ANSWER_RPM_LIMIT=8
# GEMINI_ANSWER_DAILY_BUDGET=16

# 선택 옵션
# SEND_EMAIL=false        # 웹 대시보드만 쓰고 메일은 끄기
# LOOKBACK_DAYS=1
# DOC_MAX_CHARS=8000
# SEND_EMPTY_BRIEFING=false
