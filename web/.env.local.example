# 이 파일을 .env.local로 복사하고 실제 값을 입력하세요.
# 아래 변수는 모두 서버 전용입니다. NEXT_PUBLIC_ 접두사를 붙이지 마세요.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
# 비워두면 GEMINI_MODEL을 사용합니다.
GEMINI_ANSWER_MODEL=
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=
# Phase 3 로그인용: Settings → API Keys의 publishable(anon) key.
# 원래 공개 가능한 키지만 이 프로젝트에선 서버 전용으로만 사용한다.
SUPABASE_ANON_KEY=

# 공개 질문 API rate limit. 아래 값은 모두 서버 전용 필수 설정입니다.
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_IP_HASH_KEY=
RATE_LIMIT_GLOBAL_RPM=8
# 확정 실측 한도의 80%: 답변 8 RPM/16 RPD, 임베딩 80 RPM/800 RPD
GEMINI_EMBEDDING_RPM_LIMIT=80
GEMINI_EMBEDDING_DAILY_BUDGET=800
GEMINI_ANSWER_RPM_LIMIT=8
GEMINI_ANSWER_DAILY_BUDGET=16

# match_filings RPC의 기본 검색 개수
RAG_MATCH_COUNT=8
# 이 값보다 코사인 유사도가 낮은 청크는 답변 근거에서 제외
RAG_MIN_SIMILARITY=0.35

# Phase 3 온디맨드 수집: GitHub Actions 원격 실행용
# fine-grained PAT (권한: 이 저장소의 Actions → Read and write)
GITHUB_DISPATCH_TOKEN=
GITHUB_REPO=Felix0708/stock-briefing
